---
---

<section class="section contact" id="contact">
  <div class="container">
    <div class="contact-card" data-reveal>
      <div class="contact-glow" aria-hidden="true"></div>

      <div class="contact-inner">
        <div class="contact-copy">
          <span class="eyebrow light">Bắt đầu ngay</span>
          <h2>Sẵn sàng xây dựng sản phẩm tiếp theo của bạn?</h2>
          <p>
            Để lại thông tin, đội ngũ DevLab sẽ liên hệ tư vấn miễn phí trong vòng
            24 giờ làm việc.
          </p>

          <ul class="contact-info">
            <li><span>✉️</span> hello@devlab.vn</li>
            <li><span>📞</span> 0900 123 456</li>
            <li><span>📍</span> Hà Nội · TP. Hồ Chí Minh</li>
          </ul>
        </div>

        <form class="contact-form" id="contact-form" novalidate>
          <div class="field">
            <label for="name">Họ và tên</label>
            <input id="name" name="name" type="text" placeholder="Nguyễn Văn A" required />
          </div>
          <div class="field">
            <label for="email">Email</label>
            <input id="email" name="email" type="email" placeholder="ban@congty.vn" required />
          </div>
          <div class="field">
            <label for="message">Mô tả dự án</label>
            <textarea id="message" name="message" rows="4" placeholder="Tôi cần xây dựng..." required></textarea>
          </div>
          <button class="btn btn-light" type="submit">Gửi yêu cầu tư vấn</button>
          <p class="form-note" data-note hidden>✓ Cảm ơn bạn! Chúng tôi sẽ liên hệ sớm.</p>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-card {
    position: relative;
    overflow: hidden;
    background: var(--navy-800);
    border-radius: var(--radius-lg);
    padding: clamp(36px, 5vw, 64px);
    box-shadow: var(--shadow-lg);
  }

  .contact-glow {
    position: absolute;
    top: -30%;
    left: 50%;
    transform: translateX(-50%);
    width: 60%;
    height: 70%;
    background: var(--brand-gradient);
    filter: blur(90px);
    opacity: 0.4;
  }

  .contact-inner {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }

  .eyebrow.light {
    color: var(--blue-400);
  }

  .contact-copy h2 {
    color: #fff;
    font-size: clamp(1.7rem, 3.2vw, 2.4rem);
    margin-bottom: 16px;
  }

  .contact-copy p {
    color: #aab6d4;
    font-size: 1.05rem;
    max-width: 420px;
  }

  .contact-info {
    list-style: none;
    padding: 0;
    margin-top: 28px;
    display: grid;
    gap: 12px;
  }

  .contact-info li {
    display: flex;
    align-items: center;
    gap: 12px;
    color: #d4ddf2;
    font-weight: 500;
  }

  .contact-form {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius);
    padding: 28px;
    backdrop-filter: blur(6px);
  }

  .field {
    margin-bottom: 16px;
  }

  .field label {
    display: block;
    color: #c6d0e6;
    font-size: 0.9rem;
    font-weight: 500;
    margin-bottom: 7px;
  }

  .field input,
  .field textarea {
    width: 100%;
    background: rgba(13, 19, 38, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 10px;
    padding: 12px 14px;
    color: #fff;
    font-family: inherit;
    font-size: 0.98rem;
    transition: border-color 0.18s ease, box-shadow 0.18s ease;
    resize: vertical;
  }

  .field input::placeholder,
  .field textarea::placeholder {
    color: #64748b;
  }

  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--blue-500);
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.25);
  }

  .btn-light {
    width: 100%;
    background: #fff;
    color: var(--navy-800);
    font-weight: 700;
    margin-top: 6px;
  }

  .btn-light:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 24px -10px rgba(0, 0, 0, 0.5);
  }

  .form-note {
    margin-top: 14px;
    text-align: center;
    color: #5ee0c4;
    font-weight: 600;
    font-size: 0.95rem;
  }

  @media (max-width: 860px) {
    .contact-inner {
      grid-template-columns: 1fr;
      gap: 36px;
    }
  }
</style>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const note = form?.querySelector("[data-note]") as HTMLElement | null;

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }
    form.reset();
    if (note) note.hidden = false;
  });
</script>
